// Phân tích:
// Input: 
// File fractions.csv: Chứa danh sách phân số thô (num, den).
// Output: 
// File fraction_out.csv: 
// - Dòng 1: Tiêu đề thống kê (valid_count, invalid_count, sum)
// - Dòng 2: Kết quả thống kê (ví dụ: 4, 1, 1/3)
// - Dòng 3: Tiêu đề danh sách (num, den)
// - Các dòng tiếp theo: Danh sách phân số đã được sắp xếp tăng dần.
// Yêu cầu xử lý:
// 1. Đọc dữ liệu: Bỏ qua dòng header, nạp các cặp số vào danh sách thô.
// 2. Lọc & Chuẩn hoá: Dùng hàm normalize để rút gọn, sửa mẫu âm, xử lý tử=0. Nếu mẫu=0 thì tăng invalid_count và bỏ qua.
// 3. Sắp xếp: Dùng std::sort kết hợp __int128 để nhân chéo tránh tràn số (như Bài 3 trước đây).
// 4. Tính tổng: Bắt buộc dùng phép cộng phân số chuẩn xác (không ép kiểu double). Chú ý: Cần gọi normalize() ngay sau mỗi lần cộng dồn để tránh tử/mẫu bị phình to gây tràn số ở các bước cộng tiếp theo.
// Case biên:
// - File không có phân số hợp lệ nào -> sum mặc định là 0/1.
// Thiết kế hàm:
// 1. bool readFractions()
// 2. void filterAndNormalize()
// 3. void sortFractions()
// 4. bool writeFractionReport()
#include <iostream>
#include <fstream>
#include <sstream>
#include <vector>
#include <algorithm>
#include <cstdint>
#include <string>

using namespace std;

// Cấu trúc phân số
struct Fraction {
    long long num;
    long long den;
};

// --- CÁC HÀM TIỆN ÍCH LÕI  ---
long long gcd(long long a, long long b) {
    a = abs(a);
    b = abs(b);
    while (b != 0) {
        long long t = a % b;
        a = b;
        b = t;
    }
    return a;
}

bool normalize(Fraction& f) {
    if (f.den == 0) return false;
    if (f.num == 0) {
        f.den = 1;
        return true;
    }
    if (f.den < 0) {
        f.num = -f.num;
        f.den = -f.den;
    }
    long long g = gcd(f.num, f.den);
    f.num /= g;
    f.den /= g;
    return true;
}
Fraction addFrac(Fraction f1, Fraction f2) {
    Fraction res;
    res.num = f1.num * f2.den + f2.num * f1.den;
    res.den = f1.den * f2.den;
    // Rút gọn ngay sau khi cộng để chống tràn số cho các phép cộng tiếp theo
    normalize(res); 
    return res;
}

int cmpFrac(Fraction a, Fraction b) {
    __int128_t left = (__int128_t)a.num * b.den;
    __int128_t right = (__int128_t)b.num * a.den;
    if (left < right) return -1;
    if (left > right) return 1;
    return 0;
}

// --- PIPELINE 4 HÀM CHÍNH ---

// Hàm 1: Đọc file
bool readFractions(const string& filename, vector<Fraction>& rawFractions) {
    ifstream file(filename);
    if (!file.is_open()) return false;
    
    string line;
    while (getline(file, line)) {
        if (line.empty()) continue;
        stringstream ss(line);
        string nStr, dStr;
        if (getline(ss, nStr, ',') && getline(ss, dStr)) {
            try {
                rawFractions.push_back({stoll(nStr), stoll(dStr)});
            } catch (...) {
                continue; // Bỏ qua header
            }
        }
    }
    file.close();
    return true;
}

// Hàm 2: Lọc và chuẩn hoá
void filterAndNormalize(const vector<Fraction>& raw, vector<Fraction>& valid, int& invalidCount) {
    invalidCount = 0;
    for (Fraction f : raw) {
        if (normalize(f)) {
            valid.push_back(f);
        } else {
            invalidCount++;
        }
    }
}

// Hàm 3: Sắp xếp
void sortFractions(vector<Fraction>& valid) {
    sort(valid.begin(), valid.end(), [](Fraction a, Fraction b) {
        return cmpFrac(a, b) < 0;
    });
}

// Hàm 4: Tính tổng và Ghi file
bool writeFractionReport(const string& filename, const vector<Fraction>& valid, int invalidCount) {
    ofstream file(filename);
    if (!file.is_open()) return false;

    // Tính tổng
    Fraction sum = {0, 1}; // Khởi tạo tổng bằng 0/1 (xử lý luôn case biên mảng rỗng)
    for (const Fraction& f : valid) {
        sum = addFrac(sum, f);
    }

    // Ghi phần thống kê
    file << "valid_count,invalid_count,sum\n";
    file << valid.size() << "," << invalidCount << "," << sum.num << "/" << sum.den << "\n";

    // Ghi danh sách đã sắp xếp
    file << "num,den\n";
    for (const Fraction& f : valid) {
        file << f.num << "," << f.den << "\n";
    }

    file.close();
    return true;
}
int main() {
    vector<Fraction> rawFractions;
    if (!readFractions("fractions0.csv", rawFractions)) {
        cerr << "Error: Could not read fractions.csv\n";
        return 1;
    }

    vector<Fraction> validFractions;
    int invalidCount = 0;
    filterAndNormalize(rawFractions, validFractions, invalidCount);
    
    sortFractions(validFractions);
    
    if (!writeFractionReport("fraction_out0.csv", validFractions, invalidCount)) {
        cerr << "Error: Could not write fraction_out.csv\n";
        return 1;
    }
    cout << "Processing completed. Check fraction_out.csv for results." << endl;
    return 0;
}
