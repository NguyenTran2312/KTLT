// BÀI 10 — Mini-project: Hướng A — Cleaning → Z-score → ASCII Histogram
// ============================================================
/*
 * Pipeline M0 đầy đủ, chia thành 4 hàm module rõ ràng:
 *
 *   [Module 1] loadData()         — đọc CSV nhiều cột, tách valid/missing
 *   [Module 2] computeStats()     — mean + std cho từng cột
 *   [Module 3] imputeAndZScore()  — impute missing = mean, tính Z-score
 *   [Module 4] writeReport()      — ghi report.csv + summary.txt + histogram ASCII
 *
 * ASCII Histogram:
 *   Chia dải Z-score của mỗi cột thành 10 bins đều nhau.
 *   Mỗi bin hiển thị như: "[lo, hi): ####" (mỗi # = 1 phần tử).
 *   Nếu tất cả Z-score = 0 (std = 0) → in "ALL_ZERO".
 *
 * Case biên:
 *   - Tất cả giá trị 1 cột missing → mean=0, std=0, Z-score=0 sau impute.
 *   - std = 0 (tất cả giá trị bằng nhau) → Z-score = 0.
 *   - File rỗng (không có hàng data) → báo lỗi.
 *   - Chỉ 1 hàng → std = 0 (variance quần thể n=1 chia n = 0? → không, std = 0).
 */
 
/* [Module 1] Đọc dữ liệu từ data_b10.csv. */
struct DataTable {
    vector<string>         colNames;  // tên các cột số (bỏ cột id)
    vector<string>         ids;
    // rawVals[row][col]: giá trị hoặc NaN nếu missing
    vector<vector<double>> rawVals;
    int nRows = 0, nCols = 0;
};
 
bool loadData(const string& path, DataTable& D) {
    ifstream fin(path);
    if (!fin) { cerr << "[B10] Lỗi mở '" << path << "'\n"; return false; }
 
    string line;
    if (!getline(fin, line)) { cerr << "[B10] File rỗng.\n"; return false; }
 
    auto hdr = splitCSV(line);
    if (hdr.size() < 2) { cerr << "[B10] Cần ít nhất 2 cột (id + 1 cột số).\n"; return false; }
    for (int j = 1; j < (int)hdr.size(); ++j) D.colNames.push_back(hdr[j]);
    D.nCols = (int)D.colNames.size();
 
    while (getline(fin, line)) {
        if (trim(line).empty()) continue;
        auto cells = splitCSV(line);
        D.ids.push_back(cells.empty() ? "UNKNOWN" : cells[0]);
 
        vector<double> row(D.nCols, NAN);
        for (int j = 0; j < D.nCols; ++j) {
            int ci = j + 1;
            if (ci < (int)cells.size() && !isMissing(cells[ci])) {
                try { row[j] = stod(cells[ci]); } catch (...) {}
            }
        }
        D.rawVals.push_back(row);
    }
    D.nRows = (int)D.ids.size();
    return D.nRows > 0;
}
 
/* [Module 2] Tính mean và std cho từng cột (bỏ qua NaN). */
struct StatsVec {
    vector<double> means, stds;
    vector<int>    counts, missings;
};
 
StatsVec computeStats(const DataTable& D) {
    StatsVec S;
    S.means.resize(D.nCols, 0.0);
    S.stds.resize(D.nCols, 0.0);
    S.counts.resize(D.nCols, 0);
    S.missings.resize(D.nCols, 0);
 
    for (int j = 0; j < D.nCols; ++j) {
        long double sum = 0;
        int cnt = 0;
        for (int i = 0; i < D.nRows; ++i) {
            if (!isnan(D.rawVals[i][j])) { sum += D.rawVals[i][j]; ++cnt; }
            else                          ++S.missings[j];
        }
        S.counts[j] = cnt;
        if (cnt == 0) { S.means[j] = 0.0; S.stds[j] = 0.0; continue; }
 
        S.means[j] = (double)(sum / cnt);
 
        long double varAcc = 0;
        for (int i = 0; i < D.nRows; ++i) {
            if (!isnan(D.rawVals[i][j])) {
                long double d = D.rawVals[i][j] - S.means[j];
                varAcc += d * d;
            }
        }
        S.stds[j] = (cnt > 1) ? (double)sqrt((double)(varAcc / cnt)) : 0.0;
    }
    return S;
}
 
/* [Module 3] Impute missing = mean của cột, tính Z-score.
 * imputed[row][col]  = giá trị đã impute (gốc hoặc mean nếu missing).
 * zscores[row][col]  = (imputed - mean) / std; nếu std=0 → z=0.
 */
struct ImputedTable {
    vector<vector<double>> imputed;
    vector<vector<double>> zscores;
};
 
ImputedTable imputeAndZScore(const DataTable& D, const StatsVec& S) {
    ImputedTable T;
    T.imputed.assign(D.nRows, vector<double>(D.nCols, 0.0));
    T.zscores.assign(D.nRows, vector<double>(D.nCols, 0.0));
 
    for (int i = 0; i < D.nRows; ++i) {
        for (int j = 0; j < D.nCols; ++j) {
            double val = isnan(D.rawVals[i][j]) ? S.means[j] : D.rawVals[i][j];
            T.imputed[i][j] = val;
            T.zscores[i][j] = (S.stds[j] > 1e-12)
                                 ? (val - S.means[j]) / S.stds[j]
                                 : 0.0;
        }
    }
    return T;
}
 
/* [Module 4a] Ghi report.csv: id, col1_imputed, col1_z, col2_imputed, col2_z, ... */
void writeReport(const string& path, const DataTable& D,
                 const ImputedTable& T) {
    ofstream fout(path);
    if (!fout) { cerr << "[B10] Lỗi ghi " << path << "\n"; return; }
    fout << fixed << setprecision(6);
 
    // Header
    fout << "id";
    for (const auto& col : D.colNames)
        fout << "," << col << "_imputed," << col << "_zscore";
    fout << "\n";
 
    // Data
    for (int i = 0; i < D.nRows; ++i) {
        fout << D.ids[i];
        for (int j = 0; j < D.nCols; ++j)
            fout << "," << T.imputed[i][j] << "," << T.zscores[i][j];
        fout << "\n";
    }
}
 
/* [Module 4b] Ghi summary.txt: thống kê từng cột + ASCII histogram Z-score. */
void writeSummary(const string& path, const DataTable& D,
                  const StatsVec& S, const ImputedTable& T) {
    ofstream fout(path);
    if (!fout) { cerr << "[B10] Lỗi ghi " << path << "\n"; return; }
    fout << fixed << setprecision(6);
 
    for (int j = 0; j < D.nCols; ++j) {
        fout << "=== Column: " << D.colNames[j] << " ===\n";
        fout << "count="   << S.counts[j]  << "\n";
        fout << "missing=" << S.missings[j] << "\n";
        fout << "mean="    << S.means[j]   << "\n";
        fout << "std="     << S.stds[j]    << "\n";
 
        // --- ASCII Histogram của Z-score ---
        // Thu thập tất cả z-score của cột j
        vector<double> zCol(D.nRows);
        for (int i = 0; i < D.nRows; ++i) zCol[i] = T.zscores[i][j];
 
        double zMin = *min_element(zCol.begin(), zCol.end());
        double zMax = *max_element(zCol.begin(), zCol.end());
 
        fout << "Z-score histogram:\n";
 
        // Nếu tất cả z = 0 → in thông báo đặc biệt
        if (fabs(zMax - zMin) < 1e-12) {
            fout << "  ALL_ZERO (std=0 hoac tat ca gia tri bang nhau)\n";
        } else {
            const int BINS = 10;
            double binW = (zMax - zMin) / BINS;
            vector<int> hist(BINS, 0);
 
            for (double z : zCol) {
                int bin = (int)((z - zMin) / binW);
                if (bin == BINS) bin = BINS - 1; // z = zMax vào bin cuối
                hist[bin]++;
            }
 
            for (int b = 0; b < BINS; ++b) {
                double lo = zMin + b * binW;
                double hi = lo + binW;
                // In khoảng bin [lo, hi)
                fout << setw(8) << setprecision(2) << lo
                     << " - " << setw(7) << hi << ": ";
                // Vẽ # theo số lượng phần tử trong bin
                for (int cnt = 0; cnt < hist[b]; ++cnt) fout << '#';
                fout << "  (" << hist[b] << ")\n";
            }
        }
        fout << "\n";
    }
}
 
void bai10(const string& dataPath) {
    cout << "\n[B10] === Mini-project: Cleaning + Z-score + ASCII Histogram ===\n";
 
    // [Module 1] Load
    DataTable D;
    if (!loadData(dataPath, D)) return;
    cout << "  Load: " << D.nRows << " hang, " << D.nCols << " cot so.\n";
 
    // [Module 2] Stats
    StatsVec S = computeStats(D);
    for (int j = 0; j < D.nCols; ++j) {
        cout << "  Col '" << D.colNames[j] << "': count=" << S.counts[j]
             << " miss=" << S.missings[j]
             << " mean=" << fixed << setprecision(4) << S.means[j]
             << " std="  << S.stds[j] << "\n";
    }
 
    // [Module 3] Impute + Z-score
    ImputedTable T = imputeAndZScore(D, S);
 
    // [Module 4] Write outputs
    writeReport("b10_report.csv", D, T);
    writeSummary("b10_summary.txt", D, S, T);
 
    cout << "  Da ghi: b10_report.csv, b10_summary.txt\n";
}

