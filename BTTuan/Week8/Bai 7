struct Fraction { long long num, den; };

long long gcd(long long a, long long b) {
    a = abs(a); b = abs(b);
    while (b) { long long t = a % b; a = b; b = t; }
    return a ? a : 1; // tránh gcd(0,0) = 0
}

bool normalize(Fraction& f) {
    if (f.den == 0) return false;
    if (f.den < 0) { f.num = -f.num; f.den = -f.den; }
    if (f.num == 0) { f.den = 1; return true; }
    long long g = gcd(abs(f.num), f.den);
    f.num /= g; f.den /= g;
    return true;
}

Fraction addFrac(Fraction a, Fraction b) {
    Fraction r = { a.num * b.den + b.num * a.den, a.den * b.den };
    normalize(r); return r;
}

Fraction mulFrac(Fraction a, Fraction b) {
    Fraction r = { a.num * b.num, a.den * b.den };
    normalize(r); return r;
}

Fraction divFrac(Fraction a, Fraction b) {
    if (b.num == 0) return {0, 0};
    Fraction r = { a.num * b.den, a.den * b.num };
    normalize(r); return r;
}

int cmpFrac(Fraction a, Fraction b) {
    __int128 lhs = (__int128)a.num * b.den;
    __int128 rhs = (__int128)b.num * a.den;
    if (lhs < rhs) return -1;
    if (lhs > rhs) return  1;
    return 0;
}

void printFrac(ostream& os, Fraction f) { os << f.num << "/" << f.den; }

bool fracEqual(Fraction a, Fraction b) { return cmpFrac(a, b) == 0; }


using FMatrix = vector<vector<Fraction>>;

/* [B5] Đọc ma trận phân số từ file.
 * Format: dòng đầu "m n", mỗi ô ghi "num/den".
 */
bool readFMatrix(const string& path, FMatrix& M, int& rows, int& cols) {
    ifstream fin(path);
    if (!fin) { cerr << "Lỗi mở '" << path << "'\n"; return false; }
    fin >> rows >> cols;
    M.assign(rows, vector<Fraction>(cols));
    for (int i = 0; i < rows; ++i) {
        for (int j = 0; j < cols; ++j) {
            char slash;
            fin >> M[i][j].num >> slash >> M[i][j].den;
            normalize(M[i][j]);
        }
    }
    return true;
}

/* [B5] Cộng 2 ma trận phân số (cùng kích thước). */
bool addMatrix(const FMatrix& A, const FMatrix& B, FMatrix& C,
               int ra, int ca, int rb, int cb) {
    if (ra != rb || ca != cb) return false;
    C.assign(ra, vector<Fraction>(ca));
    for (int i = 0; i < ra; ++i)
        for (int j = 0; j < ca; ++j)
            C[i][j] = addFrac(A[i][j], B[i][j]);
    return true;
}

/* [B5] Nhân 2 ma trận phân số (cols_A == rows_B). */
bool mulMatrix(const FMatrix& A, const FMatrix& B, FMatrix& C,
               int ra, int ca, int rb, int cb) {
    if (ca != rb) return false;
    C.assign(ra, vector<Fraction>(cb, {0, 1}));
    for (int i = 0; i < ra; ++i)
        for (int k = 0; k < ca; ++k)
            for (int j = 0; j < cb; ++j)
                C[i][j] = addFrac(C[i][j], mulFrac(A[i][k], B[k][j]));
    return true;
}

void writeFMatrix(ostream& os, const FMatrix& M, int r, int c) {
    for (int i = 0; i < r; ++i) {
        for (int j = 0; j < c; ++j) {
            printFrac(os, M[i][j]);
            if (j < c-1) os << "  ";
        }
        os << "\n";
    }
}


struct Poly {
    string id;
    int    deg;           // bậc; deg < 0 → invalid
    vector<double> a;     // hệ số: a[0] = hệ số bậc 0, ..., a[deg] = hệ số bậc cao nhất
    bool valid;
};

/* [B1] Đọc danh sách đa thức từ CSV.
 * Format mỗi dòng: id,degree,a0,a1,...,an
 * Thiếu hệ số → 0. degree < 0 → invalid.
 */
bool readPolysCSV(const string& path, vector<Poly>& polys, int& invalidCnt) {
    ifstream fin(path);
    if (!fin) { cerr << "Lỗi mở '" << path << "'\n"; return false; }

    invalidCnt = 0;
    string line;
    while (getline(fin, line)) {
        if (line.empty()) continue;
        stringstream ss(line);
        string token;
        vector<string> cells;
        while (getline(ss, token, ',')) cells.push_back(token);

        Poly p;
        p.valid = false;
        if (cells.size() < 2) { ++invalidCnt; polys.push_back(p); continue; }

        p.id = cells[0];
        try { p.deg = stoi(cells[1]); } catch(...) { ++invalidCnt; polys.push_back(p); continue; }

        if (p.deg < 0) { ++invalidCnt; polys.push_back(p); continue; }

        // Đọc hệ số; thiếu → 0
        p.a.resize(p.deg + 1, 0.0);
        for (int i = 0; i <= p.deg; ++i) {
            int cellIdx = i + 2;
            if (cellIdx < (int)cells.size()) {
                try { p.a[i] = stod(cells[cellIdx]); } catch(...) { p.a[i] = 0.0; }
            }
        }
        p.valid = true;
        polys.push_back(p);
    }
    return true;
}

/* [B2] Tính P(x) bằng thuật toán Horner.
 * P(x) = a[n]·xⁿ + ... + a[1]·x + a[0]
 * Horner: res = a[n]; for i=n-1..0: res = res*x + a[i]
 */
double evalHorner(const vector<double>& a, double x) {
    if (a.empty()) return 0.0;
    double res = a.back();
    for (int i = (int)a.size() - 2; i >= 0; --i)
        res = res * x + a[i];
    return res;
}

/* [B5] Tính hệ số đa thức đạo hàm P'(x).
 * Nếu P(x) = Σ a[i]·xⁱ thì P'(x) = Σ i·a[i]·x^(i-1)
 * Hệ số: deriv[i] = (i+1)·a[i+1], i = 0..deg-1
 */
vector<double> computeDerivCoeffs(const vector<double>& a) {
    if (a.size() <= 1) return {0.0}; // hằng số → đạo hàm = 0
    int n = (int)a.size() - 1;       // bậc của đa thức gốc
    vector<double> d(n);
    for (int i = 0; i < n; ++i)
        d[i] = (i + 1) * a[i + 1];
    return d;
}

// ============================================================
// BÀI 7 — Tìm nghiệm nguyên của đa thức
// ============================================================
/*
 * Thuật toán: thay từng x ∈ [-50, 50] vào P(x) bằng evalHorner().
 *   Nếu |P(x)| < eps (chọn eps = 1e-6) thì x là nghiệm.
 *
 * Chú ý: bài nói "hệ số nguyên" nhưng cấu trúc Poly dùng double,
 *   nên dùng ngưỡng epsilon thay vì so sánh == 0.
 *
 * Case biên:
 *   - Đa thức bậc 0 (hằng số):
 *       a[0] ≈ 0 → mọi x đều là nghiệm (in -50..50).
 *       a[0] ≠ 0 → không có nghiệm nguyên.
 *   - Đa thức invalid → bỏ qua.
 */
void bai7(const string& polyPath, const string& outPath) {
    vector<Poly> polys;
    int inv;
    if (!readPolysCSV(polyPath, polys, inv)) return;

    ofstream fout(outPath);
    if (!fout) { cerr << "[B7] Lỗi ghi " << outPath << "\n"; return; }

    fout << "id,root\n";
    const double EPS = 1e-6;

    for (const auto& p : polys) {
        if (!p.valid) continue;

        bool found = false;
        // Trường hợp bậc 0 (hằng số)
        if (p.deg == 0) {
            if (abs(p.a[0]) < EPS) {
                // Mọi x đều là nghiệm — in toàn bộ khoảng
                for (int x = -50; x <= 50; ++x)
                    fout << p.id << "," << x << "\n";
                found = true;
            }
            // Nếu a[0] ≠ 0 thì không có nghiệm nguyên
        } else {
            for (int x = -50; x <= 50; ++x) {
                double val = evalHorner(p.a, (double)x);
                if (abs(val) < EPS) {
                    fout << p.id << "," << x << "\n";
                    found = true;
                }
            }
        }

        if (!found) fout << p.id << ",NONE\n";
    }
    cout << "[B7] Da ghi nghiem nguyen vao " << outPath << "\n";
}


void createSampleFiles() {
    // polynomials.csv
    {
        ofstream f("polynomials.csv");
        // id, degree, a0, a1, a2, ...
        f << "P1,2,2,-3,1\n"    // P1(x) = x² - 3x + 2 → nghiệm x=1, x=2
          << "P2,3,0,1,0,-1\n"  // P2(x) = -x³ + x → nghiệm x=0,1,-1
          << "P3,0,5\n"         // P3(x) = 5 → không có nghiệm nguyên
          << "P4,-1\n"          // invalid: bậc âm
          << "P5,1,-6,1\n";     // P5(x) = x - 6 → nghiệm x=6
    }
    
}

int main() {
    createSampleFiles();

    // --- Bài 7: Nghiệm nguyên ---
    cout << "--- Bai 7: Tim nghiem nguyen x in [-50,50] ---\n";
    bai7("polynomials.csv", "b7_roots.csv");
    // P1: x=1,2; P2: x=0,1,-1; P3: NONE; P5: x=6

    return 0;
}
