/*
 * Ma trận đơn vị I_n:
 *   I[i][i] = 1/1 (đường chéo chính)
 *   I[i][j] = 0/1 với i ≠ j
 *
 * Tạo I_n, sau đó tính:
 *   AI = A × I   và kiểm tra AI = A (từng ô)
 *   IA = I × A   và kiểm tra IA = A (từng ô)
 *
 * Nếu cả 2 đều bằng A → in is_identity_product=1.
 *
 * Case biên:
 *   - n = 0 → ma trận rỗng, kết quả trivially true.
 *   - n = 1 → I = [[1/1]], nhân bất kỳ gì cũng cho lại chính nó.
 */
FMatrix makeIdentity(int n) {
    FMatrix I(n, vector<Fraction>(n, {0, 1}));
    for (int i = 0; i < n; ++i) I[i][i] = {1, 1};
    return I;
}
 
bool matrixEqual(const FMatrix& A, const FMatrix& B, int r, int c) {
    for (int i = 0; i < r; ++i)
        for (int j = 0; j < c; ++j)
            if (!fracEqual(A[i][j], B[i][j])) return false;
    return true;
}
 
void bai8(const string& matPath, const string& outPath) {
    FMatrix A;
    int ra, ca;
    if (!readFMatrix(matPath, A, ra, ca)) return;
 
    ofstream fout(outPath);
    if (!fout) { cerr << "[B8] Lỗi ghi " << outPath << "\n"; return; }
 
    // Chỉ áp dụng với ma trận vuông
    if (ra != ca) {
        fout << "is_identity_product=0\nNote: not square\n";
        cout << "[B8] Ma tran khong vuong -> skip.\n";
        return;
    }
 
    if (ra == 0) {
        fout << "is_identity_product=1\nNote: empty matrix\n";
        cout << "[B8] Ma tran rong -> trivially true.\n";
        return;
    }
 
    int n = ra;
    FMatrix I = makeIdentity(n);
 
    // Tính A × I và I × A
    FMatrix AI, IA;
    mulMatrix(A, I, AI, n, n, n, n);
    mulMatrix(I, A, IA, n, n, n, n);
 
    bool okAI = matrixEqual(AI, A, n, n);
    bool okIA = matrixEqual(IA, A, n, n);
    bool ok   = okAI && okIA;
 
    fout << "is_identity_product=" << (ok ? 1 : 0) << "\n";
    fout << "A*I == A: " << (okAI ? "YES" : "NO") << "\n";
    fout << "I*A == A: " << (okIA ? "YES" : "NO") << "\n";
 
    cout << "[B8] A*I==A: " << okAI << "  I*A==A: " << okIA
         << "  is_identity_product=" << ok << "\n";
}


