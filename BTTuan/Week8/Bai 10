        // Hợp lệ: 1/2, 3/4, 1/4, 1/1; invalid: 2/0
    }
}

int main() {
    createSampleFiles();

    // --- Bài 10: Variance phân số ---
    cout << "\n--- Bai 10: Tong binh phuong va Variance theo phan so ---\n";
    bai10("fractions.csv", "b10_stats.txt");
 
    // Case biên: file rỗng
    { ofstream f("empty_frac.csv"); }
    cout << "\n--- Bai 10 (bien): file rong ---\n";
    bai10("empty_frac.csv", "b10_empty.txt");

