struct Poly {
    string id;
    int    deg;           // bậc; deg < 0 → invalid
    vector<double> a;     // hệ số: a[0] = hệ số bậc 0, ..., a[deg] = hệ số bậc cao nhất
    bool valid;
};

/* [B1] Đọc danh sách đa thức từ CSV.
 * Format mỗi dòng: id,degree,a0,a1,...,an
 * Thiếu hệ số → 0. degree < 0 → invalid.
 */
bool readPolysCSV(const string& path, vector<Poly>& polys, int& invalidCnt) {
    ifstream fin(path);
    if (!fin) { cerr << "Lỗi mở '" << path << "'\n"; return false; }

    invalidCnt = 0;
    string line;
    while (getline(fin, line)) {
        if (line.empty()) continue;
        stringstream ss(line);
        string token;
        vector<string> cells;
        while (getline(ss, token, ',')) cells.push_back(token);

        Poly p;
        p.valid = false;
        if (cells.size() < 2) { ++invalidCnt; polys.push_back(p); continue; }

        p.id = cells[0];
        try { p.deg = stoi(cells[1]); } catch(...) { ++invalidCnt; polys.push_back(p); continue; }

        if (p.deg < 0) { ++invalidCnt; polys.push_back(p); continue; }

        // Đọc hệ số; thiếu → 0
        p.a.resize(p.deg + 1, 0.0);
        for (int i = 0; i <= p.deg; ++i) {
            int cellIdx = i + 2;
            if (cellIdx < (int)cells.size()) {
                try { p.a[i] = stod(cells[cellIdx]); } catch(...) { p.a[i] = 0.0; }
            }
        }
        p.valid = true;
        polys.push_back(p);
    }
    return true;
}

/* [B2] Tính P(x) bằng thuật toán Horner.
 * P(x) = a[n]·xⁿ + ... + a[1]·x + a[0]
 * Horner: res = a[n]; for i=n-1..0: res = res*x + a[i]
 */
double evalHorner(const vector<double>& a, double x) {
    if (a.empty()) return 0.0;
    double res = a.back();
    for (int i = (int)a.size() - 2; i >= 0; --i)
        res = res * x + a[i];
    return res;
}

/* [B5] Tính hệ số đa thức đạo hàm P'(x).
 * Nếu P(x) = Σ a[i]·xⁱ thì P'(x) = Σ i·a[i]·x^(i-1)
 * Hệ số: deriv[i] = (i+1)·a[i+1], i = 0..deg-1
 */
vector<double> computeDerivCoeffs(const vector<double>& a) {
    if (a.size() <= 1) return {0.0}; // hằng số → đạo hàm = 0
    int n = (int)a.size() - 1;       // bậc của đa thức gốc
    vector<double> d(n);
    for (int i = 0; i < n; ++i)
        d[i] = (i + 1) * a[i + 1];
    return d;
}

// ============================================================
// BÀI 10 — Tổng bình phương và Variance theo phân số chính xác
// ============================================================
/*
 * Tính chính xác bằng phân số (không dùng double):
 *   S₁ = Σ f_i           (tổng)
 *   S₂ = Σ f_i²          (tổng bình phương)
 *   n  = số phân số hợp lệ
 *
 *   E[X]  = S₁ / n
 *   E[X²] = S₂ / n
 *   Var   = E[X²] - (E[X])²
 *
 * f_i² = mulFrac(f_i, f_i)
 *
 * Case biên:
 *   - n = 0 → EMPTY.
 *   - n = 1 → Var = f₁² - f₁² = 0/1.
 *   - Tất cả phần tử bằng nhau → Var = 0/1.
 */
void bai10(const string& path, const string& outPath) {
    // Đọc fractions.csv
    ifstream fin(path);
    if (!fin) { cerr << "[B10] Lỗi mở " << path << "\n"; return; }
 
    vector<Fraction> valid;
    int invalidCnt = 0;
    string line;
    while (getline(fin, line)) {
        if (line.empty()) continue;
        stringstream ss(line);
        long long n, d; char comma;
        if (!(ss >> n >> comma >> d)) continue;
        Fraction f = {n, d};
        if (!normalize(f)) { ++invalidCnt; continue; }
        valid.push_back(f);
    }
 
    ofstream fout(outPath);
    if (!fout) { cerr << "[B10] Lỗi ghi " << outPath << "\n"; return; }
 
    long long N = (long long)valid.size();
    if (N == 0) {
        fout << "EMPTY\n";
        cout << "[B10] Khong co phan so hop le.\n";
        return;
    }
 
    // Tính S₁ = Σ f_i  và  S₂ = Σ f_i²
    Fraction S1 = {0, 1}, S2 = {0, 1};
    for (const auto& f : valid) {
        S1 = addFrac(S1, f);               // S1 += f
        S2 = addFrac(S2, mulFrac(f, f));   // S2 += f²
    }
 
    // Tạo phân số 1/N để chia
    Fraction Nfrac = {N, 1};
 
    // E[X] = S1 / N
    Fraction EX  = divFrac(S1, Nfrac);
    // E[X²] = S2 / N
    Fraction EX2 = divFrac(S2, Nfrac);
    // Var = E[X²] - (E[X])²
    Fraction EX_sq = mulFrac(EX, EX);      // (E[X])²
    // subFrac: dùng addFrac với num đổi dấu
    EX_sq.num = -EX_sq.num;               // đổi dấu để trừ
    Fraction Var = addFrac(EX2, EX_sq);
 
    fout << "n=" << N << "\n";
    fout << "sum_squares="; printFrac(fout, S2);    fout << "\n";
    fout << "E[X]=";         printFrac(fout, EX);   fout << "\n";
    fout << "E[X2]=";        printFrac(fout, EX2);  fout << "\n";
    fout << "variance=";     printFrac(fout, Var);  fout << "\n";
 
    cout << "[B10] n=" << N << "  sum_sq="; printFrac(cout, S2);
    cout << "  variance="; printFrac(cout, Var); cout << "\n";
}


