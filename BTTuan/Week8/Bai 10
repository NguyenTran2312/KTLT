struct Fraction { long long num, den; };

long long gcd(long long a, long long b) {
    a = abs(a); b = abs(b);
    while (b) { long long t = a % b; a = b; b = t; }
    return a ? a : 1; // tránh gcd(0,0) = 0
}

bool normalize(Fraction& f) {
    if (f.den == 0) return false;
    if (f.den < 0) { f.num = -f.num; f.den = -f.den; }
    if (f.num == 0) { f.den = 1; return true; }
    long long g = gcd(abs(f.num), f.den);
    f.num /= g; f.den /= g;
    return true;
}

Fraction addFrac(Fraction a, Fraction b) {
    Fraction r = { a.num * b.den + b.num * a.den, a.den * b.den };
    normalize(r); return r;
}

Fraction mulFrac(Fraction a, Fraction b) {
    Fraction r = { a.num * b.num, a.den * b.den };
    normalize(r); return r;
}

Fraction divFrac(Fraction a, Fraction b) {
    if (b.num == 0) return {0, 0};
    Fraction r = { a.num * b.den, a.den * b.num };
    normalize(r); return r;
}

int cmpFrac(Fraction a, Fraction b) {
    __int128 lhs = (__int128)a.num * b.den;
    __int128 rhs = (__int128)b.num * a.den;
    if (lhs < rhs) return -1;
    if (lhs > rhs) return  1;
    return 0;
}

void printFrac(ostream& os, Fraction f) { os << f.num << "/" << f.den; }

bool fracEqual(Fraction a, Fraction b) { return cmpFrac(a, b) == 0; }

