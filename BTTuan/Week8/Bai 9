struct Poly {
    string id;
    int    deg;           // bậc; deg < 0 → invalid
    vector<double> a;     // hệ số: a[0] = hệ số bậc 0, ..., a[deg] = hệ số bậc cao nhất
    bool valid;
};

/* [B1] Đọc danh sách đa thức từ CSV.
 * Format mỗi dòng: id,degree,a0,a1,...,an
 * Thiếu hệ số → 0. degree < 0 → invalid.
 */
bool readPolysCSV(const string& path, vector<Poly>& polys, int& invalidCnt) {
    ifstream fin(path);
    if (!fin) { cerr << "Lỗi mở '" << path << "'\n"; return false; }

    invalidCnt = 0;
    string line;
    while (getline(fin, line)) {
        if (line.empty()) continue;
        stringstream ss(line);
        string token;
        vector<string> cells;
        while (getline(ss, token, ',')) cells.push_back(token);

        Poly p;
        p.valid = false;
        if (cells.size() < 2) { ++invalidCnt; polys.push_back(p); continue; }

        p.id = cells[0];
        try { p.deg = stoi(cells[1]); } catch(...) { ++invalidCnt; polys.push_back(p); continue; }

        if (p.deg < 0) { ++invalidCnt; polys.push_back(p); continue; }

        // Đọc hệ số; thiếu → 0
        p.a.resize(p.deg + 1, 0.0);
        for (int i = 0; i <= p.deg; ++i) {
            int cellIdx = i + 2;
            if (cellIdx < (int)cells.size()) {
                try { p.a[i] = stod(cells[cellIdx]); } catch(...) { p.a[i] = 0.0; }
            }
        }
        p.valid = true;
        polys.push_back(p);
    }
    return true;
}

/* [B2] Tính P(x) bằng thuật toán Horner.
 * P(x) = a[n]·xⁿ + ... + a[1]·x + a[0]
 * Horner: res = a[n]; for i=n-1..0: res = res*x + a[i]
 */
double evalHorner(const vector<double>& a, double x) {
    if (a.empty()) return 0.0;
    double res = a.back();
    for (int i = (int)a.size() - 2; i >= 0; --i)
        res = res * x + a[i];
    return res;
}

/* [B5] Tính hệ số đa thức đạo hàm P'(x).
 * Nếu P(x) = Σ a[i]·xⁱ thì P'(x) = Σ i·a[i]·x^(i-1)
 * Hệ số: deriv[i] = (i+1)·a[i+1], i = 0..deg-1
 */
vector<double> computeDerivCoeffs(const vector<double>& a) {
    if (a.size() <= 1) return {0.0}; // hằng số → đạo hàm = 0
    int n = (int)a.size() - 1;       // bậc của đa thức gốc
    vector<double> d(n);
    for (int i = 0; i < n; ++i)
        d[i] = (i + 1) * a[i + 1];
    return d;
}

// ============================================================
// BÀI 9 — Đa thức Lagrange nội suy
// ============================================================
/*
 * Công thức Lagrange:
 *   P(x_q) = Σ_{i=0}^{n-1}  y_i * L_i(x_q)
 *
 * Với L_i(x_q) = Π_{j ≠ i} (x_q - x_j) / (x_i - x_j)
 *
 * Không cần tính hệ số đa thức — chỉ tính trực tiếp P(x_q).
 *
 * Thuật toán O(n²) cho mỗi điểm query:
 *   Với mỗi i, tính L_i(x_q) bằng vòng lặp qua j ≠ i.
 *   Tích lũy tổng weighted.
 *
 * Case biên:
 *   - n = 0 → không có đa thức, P = 0 cho mọi x_q.
 *   - n = 1 → P(x_q) = y_0 (đa thức hằng).
 *   - Điểm x_q trùng với x_i → L_i = 1, L_j = 0 → P(x_q) = y_i (đúng).
 *   - Điểm không trùng x_i nào → nội suy bình thường.
 */

struct Point { double x, y; };

double lagrange(const vector<Point>& pts, double xq) {
    int n = (int)pts.size();
    if (n == 0) return 0.0;
    if (n == 1) return pts[0].y;

    double P = 0.0;
    for (int i = 0; i < n; ++i) {
        // Tính L_i(x_q)
        double Li = 1.0;
        for (int j = 0; j < n; ++j) {
            if (j == i) continue;
            // (x_q - x_j) / (x_i - x_j)
            Li *= (xq - pts[j].x) / (pts[i].x - pts[j].x);
        }
        P += pts[i].y * Li;
    }
    return P;
}

void bai9(const string& ptsPath, const string& qryPath, const string& outPath) {
    // Đọc điểm nội suy
    ifstream fpts(ptsPath);
    if (!fpts) { cerr << "[B9] Lỗi mở " << ptsPath << "\n"; return; }

    vector<Point> pts;
    string line;
    getline(fpts, line); // bỏ header nếu có "x,y"
    // Nếu dòng đầu không parse được thì thử parse lại
    {
        stringstream ss(line);
        double a, b; char comma;
        if (ss >> a >> comma >> b) pts.push_back({a, b}); // header là data
    }
    while (getline(fpts, line)) {
        if (line.empty()) continue;
        stringstream ss(line);
        double a, b; char comma;
        if (ss >> a >> comma >> b) pts.push_back({a, b});
    }

    // Đọc query points
    ifstream fqry(qryPath);
    if (!fqry) { cerr << "[B9] Lỗi mở " << qryPath << "\n"; return; }

    vector<double> queries;
    string tok;
    while (getline(fqry, tok)) {
        if (tok.empty()) continue;
        try { queries.push_back(stod(tok)); } catch(...) {}
    }

    ofstream fout(outPath);
    if (!fout) { cerr << "[B9] Lỗi ghi " << outPath << "\n"; return; }

    fout << "x_q,P(x_q)\n";
    fout << fixed << setprecision(6);

    for (double xq : queries) {
        double val = lagrange(pts, xq);
        fout << xq << "," << val << "\n";
    }

    cout << "[B9] Noi suy Lagrange: " << pts.size() << " diem, "
         << queries.size() << " query, ghi " << outPath << "\n";
}



