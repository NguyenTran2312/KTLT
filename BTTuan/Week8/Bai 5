#include <iostream>
#include <fstream>
#include <vector>

using namespace std;

struct Fraction
{
    long long num, den;
};

// Tìm UCLN
long long gcd(long long a, long long b)
{
    a = abs(a);
    b = abs(b);

    while(b)
    {
        long long r = a % b;
        a = b;
        b = r;
    }

    return a;
}

// Chuẩn hóa phân số
void normalize(Fraction &f)
{
    if(f.num == 0)
    {
        f.den = 1;
        return;
    }

    long long g = gcd(f.num, f.den);

    f.num /= g;
    f.den /= g;

    if(f.den < 0)
    {
        f.num *= -1;
        f.den *= -1;
    }
}

// Cộng 2 phân số
Fraction addFrac(Fraction a, Fraction b)
{
    Fraction c;

    c.num = a.num * b.den + b.num * a.den;
    c.den = a.den * b.den;

    normalize(c);

    return c;
}

// Nhân 2 phân số
Fraction mulFrac(Fraction a, Fraction b)
{
    Fraction c;

    c.num = a.num * b.num;
    c.den = a.den * b.den;

    normalize(c);

    return c;
}

typedef vector<vector<Fraction>> FMatrix;

// Cộng 2 ma trận
bool addMatrix(FMatrix A, FMatrix B, FMatrix &C)
{
    if(A.size() != B.size() ||
       A[0].size() != B[0].size())
    {
        return false;
    }

    int m = A.size();
    int n = A[0].size();

    C.resize(m, vector<Fraction>(n));

    for(int i = 0; i < m; i++)
    {
        for(int j = 0; j < n; j++)
        {
            C[i][j] = addFrac(A[i][j], B[i][j]);
        }
    }

    return true;
}

// Nhân 2 ma trận
bool mulMatrix(FMatrix A, FMatrix B, FMatrix &C)
{
    if(A[0].size() != B.size())
    {
        return false;
    }

    int m = A.size();
    int n = B[0].size();
    int k = A[0].size();

    C.resize(m, vector<Fraction>(n, {0,1}));

    for(int i = 0; i < m; i++)
    {
        for(int j = 0; j < n; j++)
        {
            for(int t = 0; t < k; t++)
            {
                C[i][j] =
                addFrac(C[i][j],
                mulFrac(A[i][t], B[t][j]));
            }
        }
    }

    return true;
}

// Đọc ma trận từ file
FMatrix readMatrix(string fileName)
{
    ifstream fin(fileName);

    int m, n;

    fin >> m >> n;

    FMatrix A(m, vector<Fraction>(n));

    for(int i = 0; i < m; i++)
    {
        for(int j = 0; j < n; j++)
        {
            char c;

            fin >> A[i][j].num >> c >> A[i][j].den;

            normalize(A[i][j]);
        }
    }

    return A;
}

// Ghi ma trận ra file
void writeMatrix(ofstream &fout, FMatrix A)
{
    for(int i = 0; i < A.size(); i++)
    {
        for(int j = 0; j < A[i].size(); j++)
        {
            fout << A[i][j].num
                 << "/"
                 << A[i][j].den
                 << " ";
        }

        fout << endl;
    }
}

int main()
{
    FMatrix A = readMatrix("matA.csv");
    FMatrix B = readMatrix("matB.csv");

    ofstream fout("result.csv");

    FMatrix C;

    fout << "=== A+B ===" << endl;

    if(addMatrix(A, B, C))
    {
        writeMatrix(fout, C);
    }
    else
    {
        fout << "INCOMPATIBLE" << endl;
    }

    fout << "=== A*B ===" << endl;

    if(mulMatrix(A, B, C))
    {
        writeMatrix(fout, C);
    }
    else
    {
        fout << "INCOMPATIBLE" << endl;
    }
}
