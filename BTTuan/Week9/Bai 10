using namespace std;


/* [B1] Trim khoảng trắng đầu/cuối. */
string trim(const string& s) {
    int l = 0, r = (int)s.size() - 1;
    while (l <= r && isspace((unsigned char)s[l])) ++l;
    while (r >= l && isspace((unsigned char)s[r])) --r;
    return s.substr(l, r - l + 1);
}

/* [B1] Normalize 1 dòng văn bản:
 *   1. Chuyển lowercase.
 *   2. Mọi ký tự không phải chữ/số (non-alphanum) → space.
 *   3. Gom nhiều space liên tiếp thành 1 space.
 *   4. Trim đầu/cuối.
 * Chỉ xử lý ASCII (isalnum sẽ trả false với ký tự UTF-8 đa byte).
 */
string normalizeLine(const string& s) {
    string result;
    bool prevSpace = true; // bắt đầu coi như đang ở space để không thêm space đầu
    for (unsigned char ch : s) {
        if (isalnum(ch)) {
            result += tolower(ch);
            prevSpace = false;
        } else {
            // Ký tự đặc biệt → space; gom liên tiếp thành 1
            if (!prevSpace) {
                result += ' ';
                prevSpace = true;
            }
        }
    }
    // Bỏ space cuối nếu có
    if (!result.empty() && result.back() == ' ')
        result.pop_back();
    return result;
}

/* [B2] Tách chuỗi đã normalize thành danh sách token theo khoảng trắng. */
vector<string> tokenize(const string& normalizedLine) {
    vector<string> tokens;
    stringstream ss(normalizedLine);
    string tok;
    while (ss >> tok) tokens.push_back(tok);
    return tokens;
}

/* [B3] Top-K từ xuất hiện nhiều nhất.
 * Sắp xếp: giảm theo count; nếu bằng → tăng theo thứ tự từ điển.
 */
vector<pair<string,int>> topK(const unordered_map<string,int>& freq, int k) {
    vector<pair<string,int>> vec(freq.begin(), freq.end());
    sort(vec.begin(), vec.end(), [](const pair<string,int>& a,
                                    const pair<string,int>& b) {
        if (a.second != b.second) return a.second > b.second; // giảm theo count
        return a.first < b.first;                              // tăng theo từ
    });
    if (k >= 0 && k < (int)vec.size()) vec.resize(k);
    return vec;
}

/* [B4] Đọc danh sách stopwords từ file (1 từ mỗi dòng, đã normalize). */
unordered_set<string> loadStopwords(const string& path) {
    unordered_set<string> stops;
    ifstream fin(path);
    if (!fin) return stops; // không có file → stop empty (không lọc gì)
    string line;
    while (getline(fin, line)) {
        string w = normalizeLine(trim(line));
        if (!w.empty()) stops.insert(w);
    }
    return stops;
}

/* [B4] Lọc token theo stopwords. */
vector<string> filterStopwords(const vector<string>& tokens,
                                const unordered_set<string>& stops) {
    vector<string> out;
    for (const auto& t : tokens)
        if (!stops.count(t)) out.push_back(t);
    return out;
}

/* [B5] Xây dựng bảng tần suất từ danh sách token. */
unordered_map<string,int> buildFreqMap(const vector<string>& tokens) {
    unordered_map<string,int> freq;
    for (const auto& t : tokens) freq[t]++;
    return freq;
}

/* Hàm tiện ích: đọc toàn bộ file text, normalize từng dòng, trả về vector token. */
vector<string> readAndTokenizeFile(const string& path) {
    ifstream fin(path);
    if (!fin) { cerr << "Lỗi mở '" << path << "'\n"; return {}; }
    vector<string> allTokens;
    string line;
    while (getline(fin, line)) {
        string norm = normalizeLine(line);
        auto toks = tokenize(norm);
        for (auto& t : toks) allTokens.push_back(t);
    }
    return allTokens;
}

// ============================================================
// BÀI 10 — TF-IDF đơn giản trên tập file
// ============================================================
/*
 * Định nghĩa:
 *   TF(w, d) = count(w, d) / total_tokens(d)     — tần suất từ trong 1 tài liệu
 *   IDF(w)   = log(N / df(w))                    — inverse document frequency
 *              N   = tổng số file
 *              df(w) = số file chứa từ w (document frequency)
 *   TF-IDF(w, d) = TF(w, d) × IDF(w)
 *
 * Thuật toán:
 *   1. Đọc danh sách file từ index.txt.
 *   2. Với mỗi file: normalize → tokenize → đếm tần suất (freq map).
 *   3. Tính df(w): đếm số file có từ w (dùng unordered_set per file).
 *   4. Tính IDF(w) = log(N / df(w)) với log tự nhiên.
 *   5. Với mỗi file: tính TF-IDF cho từng từ, lấy top-5.
 *   6. Ghi tfidf.csv: file, word, tfidf.
 *
 * Case biên:
 *   - File trong index.txt không tồn tại → bỏ qua.
 *   - Từ xuất hiện trong tất cả file → IDF = log(1) = 0 → TF-IDF = 0.
 *   - File rỗng → không có từ → không ghi gì cho file đó.
 *   - df(w) = 0 → không thể xảy ra vì w được tính sau khi đã có ít nhất 1 file chứa w.
 */
void bai10(const string& indexPath, const string& outPath) {
    // Bước 1: đọc danh sách file
    ifstream fidx(indexPath);
    if (!fidx) { cerr << "[B10] Lỗi mở " << indexPath << "\n"; return; }
 
    vector<string> filenames;
    string fname;
    while (getline(fidx, fname)) {
        fname = trim(fname);
        if (!fname.empty()) filenames.push_back(fname);
    }
 
    int N = (int)filenames.size();
    if (N == 0) {
        cerr << "[B10] index.txt rong.\n"; return;
    }
 
    // Bước 2: đọc và tokenize từng file
    // docTokens[i] = tất cả token của file i
    // docFreq[i]   = tần suất từ trong file i
    vector<vector<string>>               docTokens(N);
    vector<unordered_map<string,int>>    docFreq(N);
 
    // Bước 3: tính df — số file chứa từ w
    unordered_map<string,int> df; // df[w] = số file có từ w
 
    for (int i = 0; i < N; ++i) {
        docTokens[i] = readAndTokenizeFile(filenames[i]);
        docFreq[i]   = buildFreqMap(docTokens[i]);
 
        // Đánh dấu từng từ xuất hiện ở file i vào df (không đếm trùng trong cùng file)
        unordered_set<string> seen;
        for (const auto& t : docTokens[i]) {
            if (!seen.count(t)) {
                df[t]++;
                seen.insert(t);
            }
        }
    }
 
    ofstream fout(outPath);
    if (!fout) { cerr << "[B10] Lỗi ghi " << outPath << "\n"; return; }
 
    fout << fixed << setprecision(6);
    fout << "file,word,tfidf\n";
 
    // Bước 4 & 5: tính TF-IDF cho từng file, lấy top-5
    for (int i = 0; i < N; ++i) {
        long long totalToks = (long long)docTokens[i].size();
        if (totalToks == 0) continue; // file rỗng → bỏ qua
 
        // Tính TF-IDF cho từng từ trong file i
        vector<pair<string, double>> tfidfVec;
        for (const auto& entry : docFreq[i]) {
            const string& word = entry.first;
            int cnt            = entry.second;
            double tf  = (double)cnt / (double)totalToks;
            double idf = log((double)N / (double)df[word]); // log tự nhiên
            double val = tf * idf;
            tfidfVec.push_back({word, val});
        }
 
        // Sắp xếp giảm theo TF-IDF; nếu bằng → tăng theo từ
        sort(tfidfVec.begin(), tfidfVec.end(),
             [](const pair<string,double>& a, const pair<string,double>& b) {
                 if (fabs(a.second - b.second) > 1e-12) return a.second > b.second;
                 return a.first < b.first;
             });
 
        // Lấy top-5
        int show = min((int)tfidfVec.size(), 5);
        for (int k = 0; k < show; ++k) {
            fout << filenames[i] << ","
                 << tfidfVec[k].first << ","
                 << tfidfVec[k].second << "\n";
        }
    }
 
    cout << "[B10] TF-IDF: " << N << " file, ghi top-5 moi file vao " << outPath << "\n";
}


void createSampleFiles() {
    // doc1.txt, doc2.txt, doc3.txt cho TF-IDF
    {
        ofstream f1("doc1.txt");
        f1 << "data science machine learning deep learning neural network\n"
           << "machine learning is a subset of artificial intelligence\n";
        ofstream f2("doc2.txt");
        f2 << "python programming language data analysis\n"
           << "data science uses python and statistics\n";
        ofstream f3("doc3.txt");
        f3 << "neural network deep learning image recognition\n"
           << "convolutional neural network for image classification\n";
    }
    // index.txt — danh sách file cho TF-IDF
    {
        ofstream f("index.txt");
        f << "doc1.txt\ndoc2.txt\ndoc3.txt\n";
    }
    
}

