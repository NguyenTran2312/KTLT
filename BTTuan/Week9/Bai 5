#include <iostream>
#include <fstream>
#include <sstream>
#include <string>
#include <unordered_map>
#include <algorithm>
#include <cctype>

using namespace std;

// Chuyển chuỗi về chữ thường để chuẩn hóa token
string toLower(const string& s) {
    string result = s;
    transform(result.begin(), result.end(), result.begin(), ::tolower);
    return result;
}

// Loại bỏ ký tự không phải chữ/số ở đầu và cuối token
string trim(const string& s) {
    int start = 0, end = (int)s.size() - 1;
    while (start <= end && !isalnum((unsigned char)s[start])) start++;
    while (end >= start && !isalnum((unsigned char)s[end])) end--;
    return (start > end) ? "" : s.substr(start, end - start + 1);
}

// Đọc file văn bản, tokenize từng dòng, đếm tần suất từng token vào map
unordered_map<string, int> buildFreqMap(const string& filename) {
    unordered_map<string, int> freq;
    ifstream fin(filename);
    string line, token;
    while (getline(fin, line)) {
        istringstream iss(line);
        while (iss >> token) {
            token = toLower(trim(token));
            if (!token.empty()) freq[token]++;
        }
    }
    return freq;
}

// Hợp nhất 2 unordered_map tần suất thành 1 map chung chứa tất cả key từ cả 2 file
// output[key] = {count_file1, count_file2} — dùng pair để truyền vào writeCSV
void mergeFreq(const unordered_map<string, int>& map1,
               const unordered_map<string, int>& map2,
               unordered_map<string, pair<int,int>>& output) {
    // Duyệt tất cả key trong map1
    for (const auto& [word, cnt] : map1) {
        output[word].first = cnt;
    }
    // Duyệt tất cả key trong map2 (key chưa có sẽ được tạo với first=0)
    for (const auto& [word, cnt] : map2) {
        output[word].second = cnt;
    }
}

// Ghi kết quả so sánh ra file CSV: word, count_file1, count_file2
// Giá trị 0 nếu từ không xuất hiện trong file tương ứng
void writeComparisonCSV(const string& filename,
                        const unordered_map<string, pair<int,int>>& data) {
    ofstream fout(filename);
    fout << "word,count_file1,count_file2\n";
    for (const auto& [word, counts] : data) {
        fout << word << "," << counts.first << "," << counts.second << "\n";
    }
}

// Ghi file summary: only_in_1=<n>, only_in_2=<m>, in_both=<k>
void writeSummary(const string& filename,
                  const unordered_map<string, pair<int,int>>& data) {
    int only1 = 0, only2 = 0, both = 0;
    for (const auto& [word, counts] : data) {
        if      (counts.first > 0 && counts.second == 0) only1++;
        else if (counts.first == 0 && counts.second > 0) only2++;
        else                                              both++;
    }
    ofstream fout(filename);
    fout << "only_in_1=" << only1
         << ",only_in_2=" << only2
         << ",in_both="   << both << "\n";

    cout << "only_in_1=" << only1
              << ", only_in_2=" << only2
              << ", in_both=" << both << "\n";
}

int main() {
    const string file1      = "file1.txt";
    const string file2      = "file2.txt";
    const string compOut    = "comparison.csv";
    const string summaryOut = "summary.txt";

    // Xây dựng bảng tần suất cho từng file
    auto map1 = buildFreqMap(file1);
    auto map2 = buildFreqMap(file2);

    // Hợp nhất 2 map để so sánh
    unordered_map<string, pair<int,int>> merged;
    mergeFreq(map1, map2, merged);

    writeComparisonCSV(compOut, merged);
    writeSummary(summaryOut, merged);

    cout << "Bai 5: So sanh 2 file\n";
    cout << "Da ghi: " << compOut << ", " << summaryOut << "\n";

    return 0;
}
