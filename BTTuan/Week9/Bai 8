// BÀI 8 — Tần suất ký tự a-z
// ============================================================
/*
 * Đếm tần suất 26 ký tự a-z trên toàn bộ file (bỏ qua mọi ký tự khác).
 * Không cần normalize dòng — đọc thô từng ký tự, isalpha + tolower.
 *
 * Output: char_freq.csv gồm 26 dòng a-z, kể cả count = 0.
 *
 * Case biên:
 *   - File rỗng → tất cả count = 0.
 *   - File chỉ số và dấu → tất cả count = 0.
 *   - Ký tự hoa → đếm chung với thường (tol ower trước khi đếm).
 */
void bai8(const string& textPath, const string& outPath) {
    ifstream fin(textPath);
    if (!fin) { cerr << "[B8] Lỗi mở " << textPath << "\n"; return; }
 
    long long charFreq[26] = {};   // khởi tạo tất cả = 0
 
    char ch;
    while (fin.get(ch)) {
        unsigned char uc = (unsigned char)ch;
        if (isalpha(uc)) {
            charFreq[tolower(uc) - 'a']++;
        }
    }
 
    ofstream fout(outPath);
    if (!fout) { cerr << "[B8] Lỗi ghi " << outPath << "\n"; return; }
 
    fout << "char,count\n";
    long long total = 0;
    for (int i = 0; i < 26; ++i) {
        fout << (char)('a' + i) << "," << charFreq[i] << "\n";
        total += charFreq[i];
    }
 
    cout << "[B8] Tong ky tu chu: " << total
         << ", ghi char_freq vao " << outPath << "\n";
    // In top-3 ký tự phổ biến nhất để xác nhận nhanh
    int idx[26]; iota(idx, idx+26, 0);
    sort(idx, idx+26, [&](int a, int b){ return charFreq[a] > charFreq[b]; });
    cout << "       Top-3: ";
    for (int k = 0; k < 3 && k < 26; ++k)
        cout << (char)('a'+idx[k]) << "=" << charFreq[idx[k]] << " ";
    cout << "\n";
}


