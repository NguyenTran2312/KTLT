    createSampleFiles();

    // --- Bài 8: Tần suất ký tự ---
    cout << "\n--- Bai 8: Tan suat ky tu a-z ---\n";
    bai8("text.txt", "b8_charfreq.csv");
 
    // Case biên: file rỗng
    { ofstream f("empty.txt"); }
    cout << "       (Bien) File rong: ";
    bai8("empty.txt", "b8_empty.csv");

