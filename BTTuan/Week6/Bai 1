// Phân tích 
// Input: 
// File matrix.txt: Chứa ma trận kích thước m x n gồm các số nguyên.
// Output:
// File row_sums.txt: Ghi tổng từng hàng (mỗi dòng định dạng: i, tổng_hàng_i).
// File col_sums.txt: Ghi tổng từng cột (mỗi dòng định dạng: j, tổng_cột_j).
// Case biên:
// Ma trận 1x1; nếu m=0 hoặc n=0 thì ghi ra file output rỗng.
// Thiết kế hàm:
// vector<long long> rowSums(const vector<vector<int>>& matrix): Tính tổng từng hàng của ma trận.
// vector<long long> colSums(const vector<vector<int>>& matrix): Tính tổng từng cột của ma trận.
// Hàm đọc file: bool readMatrix(const string& filename, vector<vector<int>>& matrix): Đọc dữ liệu từ file text và nạp vào vector 2 chiều.
// Hàm ghi file: bool writeSums(const string& filename, const vector<long long>& sums): Ghi mảng kết quả ra file txt, mỗi dòng in ra chỉ số index và giá trị sums[index].
// Pipeline:
// Đọc matrix.txt: Lấy dữ liệu ma trận nạp vào biến matrix.
// Kiểm tra case biên: Nếu matrix rỗng (m=0) hoặc matrix[0] rỗng (n=0), tạo file row_sums.txt và col_sums.txt rỗng rồi kết thúc sớm.
// Gọi hàm rowSums & colSums: Truyền ma trận đã đọc vào để lấy 2 vector chứa tổng hàng và tổng cột tương ứng.
// Ghi kết quả: Xuất mảng tổng hàng vào row_sums.txt và mảng tổng cột vào col_sums.txt.

#include <iostream>
#include <vector>
#include <fstream>
#include <string>
#include <sstream>

using namespace std;

// Hàm đọc file ma trận từ matrix.txt
bool readMatrix(const string& filename, vector<vector<int>>& matrix) {
    ifstream file(filename);
    if (!file.is_open()) {
        cerr << "Error opening file: " << filename << endl;
        return false;
    }
    string line;
    while (getline(file, line)) {
        if (line.empty()) continue; // Bỏ qua dòng trống
        vector<int> row;
        stringstream ss(line);
        int value;
        while (ss >> value) {
            row.push_back(value);
        }
        matrix.push_back(row);
    }
    file.close();
    return true;
}

// Hàm tính tổng từng hàng của ma trận
vector<long long> rowSums(const vector<vector<int>>& matrix) {
    if (matrix.empty() || matrix[0].empty()) return {};
    
    int m = matrix.size();
    int n = matrix[0].size();
    vector<long long> res(m, 0);
    
    for (int i = 0; i < m; ++i) {
        for (int j = 0; j < n; ++j) {
            res[i] += matrix[i][j];
        }
    }
    return res;
}
// Hàm tính tổng từng cột của ma trận
vector<long long> colSums(const vector<vector<int>>& matrix) {
    if (matrix.empty() || matrix[0].empty()) return {}; 
    
    int m = matrix.size();
    int n = matrix[0].size();
    vector<long long> res(n, 0);

    for (int j = 0; j < n; ++j) {
        for (int i = 0; i < m; ++i) {
            res[j] += matrix[i][j];
        }
    }
    return res;
}

// Hàm ghi kết quả tổng hàng hoặc tổng cột ra file txt
bool writeSums(const string& filename, const vector<long long>& sums) {
    ofstream file(filename);
    if (!file.is_open()) {
        cerr << "Error opening file: " << filename << endl;
        return false;
    }
    for (size_t i = 0; i < sums.size(); ++i) {
        file << i << ", " << sums[i] << "\n";
    }
    file.close();
    return true;
}
int main() {
    vector<vector<int>> matrix;
    
    // Đọc ma trận từ file
    if (!readMatrix("matrix.txt", matrix)) return 1;

    // Tính tổng hàng và tổng cột
    vector<long long> row_sums = rowSums(matrix);
    vector<long long> col_sums = colSums(matrix);

    // Ghi kết quả ra file
    if (!writeSums("row_sums.txt", row_sums)) return 1;
    if (!writeSums("col_sums.txt", col_sums)) return 1;

    return 0;
}
