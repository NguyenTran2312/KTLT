// Kiểu tiện dụng cho ma trận số nguyên
using Matrix = vector<vector<long long>>;

/* [B1] Đọc ma trận m×n từ file.
 * Format file: dòng đầu "<m> <n>", sau đó m dòng × n số nguyên.
 * Trả về false và in cerr nếu không mở được file.
 */
bool readMatrix(const string& path, Matrix& mat, int& m, int& n) {
    ifstream fin(path);
    if (!fin) {
        cerr << "[readMatrix] Lỗi: không mở được file '" << path << "'\n";
        return false;
    }
    fin >> m >> n;
    mat.assign(m, vector<long long>(n, 0));
    for (int i = 0; i < m; ++i)
        for (int j = 0; j < n; ++j)
            fin >> mat[i][j];
    return true;
}

/* [B2] Kiểm tra ma trận vuông n×n có đối xứng không.
 * a[i][j] == a[j][i] với mọi i < j.
 */
bool isSymmetric(const Matrix& mat, int n) {
    for (int i = 0; i < n; ++i)
        for (int j = i + 1; j < n; ++j)
            if (mat[i][j] != mat[j][i]) return false;
    return true;
}

/* [B3] Xây dựng prefix sum 2D.
 * pre[i][j] = tổng tất cả phần tử trong hình chữ nhật (0,0)→(i,j).
 * Công thức: pre[i][j] = a[i][j]
 *                       + pre[i-1][j]   (hàng trên)
 *                       + pre[i][j-1]   (cột trái)
 *                       - pre[i-1][j-1] (bù góc tính 2 lần)
 */
Matrix buildPre2D(const Matrix& a, int m, int n) {
    Matrix pre(m, vector<long long>(n, 0));
    for (int i = 0; i < m; ++i) {
        for (int j = 0; j < n; ++j) {
            pre[i][j] = a[i][j];
            if (i > 0) pre[i][j] += pre[i-1][j];
            if (j > 0) pre[i][j] += pre[i][j-1];
            if (i > 0 && j > 0) pre[i][j] -= pre[i-1][j-1];
        }
    }
    return pre;
}

/* [B4] Truy vấn tổng vùng chữ nhật (x1,y1)→(x2,y2) — O(1).
 * Công thức bù trừ từ prefix 2D.
 * Trả về false nếu chỉ số không hợp lệ.
 */
bool sumRect(const Matrix& pre,
             int x1, int y1, int x2, int y2,
             int m, int n, long long& ans) {
    if (x1 < 0 || y1 < 0 || x2 >= m || y2 >= n || x1 > x2 || y1 > y2)
        return false;
    ans = pre[x2][y2];
    if (x1 > 0) ans -= pre[x1-1][y2];
    if (y1 > 0) ans -= pre[x2][y1-1];
    if (x1 > 0 && y1 > 0) ans += pre[x1-1][y1-1];
    return true;
}

/* [B5] Tổng đường chéo chính và phụ của ma trận vuông. */
void diagSums(const Matrix& mat, int n, long long& mainD, long long& antiD) {
    mainD = antiD = 0;
    for (int i = 0; i < n; ++i) {
        mainD += mat[i][i];
        antiD += mat[i][n-1-i];
    }
}

// ============================================================
// BÀI 7 — Vùng con tổng lớn nhất (brute-force)
// ============================================================
/*
 * Ý tưởng:
 *   Duyệt tất cả O(m²·n²) cặp (x1,y1,x2,y2) với x1≤x2, y1≤y2.
 *   Dùng sumRect() tính tổng vùng trong O(1) — nhờ prefix 2D từ B3.
 *   Lưu lại vùng có tổng lớn nhất.
 *
 * Độ phức tạp: O(m²n²) — bài cho m,n ≤ 50 nên tối đa ~1.5M lần duyệt.
 *
 * Case biên:
 *   - ma trận 1×1 → vùng duy nhất là chính ô đó.
 *   - Toàn số âm → vùng tốt nhất là ô lớn nhất (1×1).
 *   - m=0 hoặc n=0 → in EMPTY.
 */
struct RectAns {
    long long maxSum;
    int x1, y1, x2, y2;
};

RectAns maxRectSum(const Matrix& pre, int m, int n) {
    RectAns best;
    best.maxSum = LLONG_MIN;
    best.x1 = best.y1 = best.x2 = best.y2 = 0;

    for (int x1 = 0; x1 < m; ++x1) {
        for (int x2 = x1; x2 < m; ++x2) {
            for (int y1 = 0; y1 < n; ++y1) {
                for (int y2 = y1; y2 < n; ++y2) {
                    long long s;
                    sumRect(pre, x1, y1, x2, y2, m, n, s);
                    if (s > best.maxSum) {
                        best.maxSum = s;
                        best.x1 = x1; best.y1 = y1;
                        best.x2 = x2; best.y2 = y2;
                    }
                }
            }
        }
    }
    return best;
}

void bai7(const string& matPath, const string& outPath) {
    Matrix mat; int m, n;
    if (!readMatrix(matPath, mat, m, n)) return;

    // Case biên: ma trận rỗng
    if (m == 0 || n == 0) {
        ofstream fout(outPath);
        fout << "EMPTY\n";
        cout << "[B7] Ma tran rong.\n";
        return;
    }

    Matrix pre = buildPre2D(mat, m, n);
    RectAns ans = maxRectSum(pre, m, n);

    ofstream fout(outPath);
    if (!fout) { cerr << "[B7] Lỗi ghi " << outPath << "\n"; return; }

    fout << "max_sum=" << ans.maxSum << "\n";
    fout << "x1=" << ans.x1 << " y1=" << ans.y1
         << " x2=" << ans.x2 << " y2=" << ans.y2 << "\n";

    cout << "[B7] max_sum=" << ans.maxSum
         << "  vung (" << ans.x1 << "," << ans.y1
         << ")→(" << ans.x2 << "," << ans.y2 << ")\n";
}

